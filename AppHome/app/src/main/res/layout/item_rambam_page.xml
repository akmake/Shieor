<?xml version="1.0" encoding="utf-8"?>
<!--
  Rambam daily reading page.
  Each page is one day in the 334-day cycle.
  Layout:  title → decorative divider → [loader | error | dynamic content].
  Content is populated programmatically by RambamPagerAdapter (halakhot with big Hebrew ordinals).
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rambamScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rambam_bg"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp">

        <!-- Chapter / tractate title -->
        <TextView
            android:id="@+id/rambamTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/frank_ruhl_libre"
            android:gravity="center"
            android:text="טוען הלכות..."
            android:textColor="@color/rambam_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <!-- Day subtitle -->
        <TextView
            android:id="@+id/rambamChapters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/assistant"
            android:gravity="center"
            android:text="יום"
            android:textColor="@color/rambam_primary"
            android:textSize="13sp"
            android:alpha="0.65" />

        <!-- Decorative teal underline -->
        <View
            android:layout_width="44dp"
            android:layout_height="3dp"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="20dp"
            android:background="@color/rambam_primary" />

        <!-- Loading spinner (hidden once content arrives) -->
        <ProgressBar
            android:id="@+id/rambamLoader"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:indeterminateTint="@color/rambam_primary" />

        <!-- Error state -->
        <LinearLayout
            android:id="@+id/errorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/errorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/assistant"
                android:text="אין חיבור לאינטרנט"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="נסה שוב"
                android:textColor="@color/rambam_primary" />

        </LinearLayout>

        <!--
          Dynamic content container.
          RambamPagerAdapter.ViewHolder.buildContent() fills this with:
            • chapter headers (פרק א / פרק ב …) when there are multiple chapters
            • halakha rows: [large teal letter] [Hebrew text]
        -->
        <LinearLayout
            android:id="@+id/rambamContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

