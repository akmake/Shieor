                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/assistant"
                            android:text="×ž×©×™×ž×•×ª"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
