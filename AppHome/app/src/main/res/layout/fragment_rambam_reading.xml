<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/rambam_bg">

    <!-- ══ Toolbar ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:background="@color/rambam_bg">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/readingBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="חזור"
            app:tint="@color/rambam_primary" />

        <!-- Book title — centered, takes remaining space -->
        <TextView
            android:id="@+id/readingTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="@font/frank_ruhl_libre"
            android:text=""
            android:textColor="@color/rambam_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Settings gear -->
        <ImageView
            android:id="@+id/readingSettingsBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="הגדרות"
            app:tint="@color/rambam_primary" />

    </LinearLayout>

    <!-- Thin teal accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/rambam_divider" />

    <!-- Chapter range subtitle (e.g. "פרקים ד-ו הלכות תשובה") -->
    <TextView
        android:id="@+id/readingChaptersSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:paddingHorizontal="22dp"
        android:gravity="center"
        android:fontFamily="@font/assistant"
        android:text=""
        android:textColor="@color/rambam_primary"
        android:textSize="13sp"
        android:alpha="0.75" />

    <!-- Decorative teal bar under subtitle -->
    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginBottom="6dp"
        android:background="@color/rambam_primary" />

    <!-- ══ Scrollable content ════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/readingScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="8dp"
            android:paddingBottom="80dp">

            <!-- Loading spinner -->
            <ProgressBar
                android:id="@+id/readingLoader"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:indeterminateTint="@color/rambam_primary" />

            <!-- Error state -->
            <LinearLayout
                android:id="@+id/readingErrorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="32dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/readingErrorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/assistant"
                    android:text="אין חיבור לאינטרנט"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/readingRetryBtn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="נסה שוב"
                    android:textColor="@color/rambam_primary" />

            </LinearLayout>

            <!-- Dynamic halakhot content — populated by RambamReadingFragment -->
            <LinearLayout
                android:id="@+id/readingContentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ Bottom bar — auto-scroll toggle ══════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/rambam_bg"
        android:elevation="4dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/rambam_divider"
            android:layout_gravity="top" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/readingAutoScrollBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="גלילה אוטומטית"
            android:textSize="13sp"
            android:textColor="@color/rambam_primary"
            app:strokeColor="@color/rambam_primary"
            app:strokeWidth="1.5dp"
            app:icon="@drawable/ic_play_arrow"
            app:iconSize="14dp"
            app:iconTint="@color/rambam_primary"
            app:iconGravity="textStart"
            app:cornerRadius="19dp" />

    </FrameLayout>

</LinearLayout>
